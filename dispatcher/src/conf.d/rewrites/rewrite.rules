#
# This file contains the rewrite rules, and can be customized.
#
# By default, it includes just the rewrite rules. You can
# add rewrite rules to this file but you should still include
# the default rewrite rules.

Include conf.d/rewrites/default_rewrite.rules

# rewrite for root redirect
RewriteRule ^/?$ /content/${CONTENT_FOLDER_NAME}/gb/en/home.html [PT,L]
RewriteRule ^/index.html /content/${CONTENT_FOLDER_NAME}/gb/en/home.html [PT,L]

RewriteCond %{REQUEST_URI} ^/assets
RewriteRule ^/assets/(.*) /content/dam/${CONTENT_FOLDER_NAME}/gb/$1 [PT,L]

RewriteCond %{REQUEST_URI} ^/library.html
RewriteRule ^/library/(.*) /content/component-library.html [PT,L]

RewriteCond %{REQUEST_URI} ^/library
RewriteRule ^/library/(.*) /content/component-library/$1 [PT,L]

RewriteCond %{REQUEST_URI} ^/api
RewriteRule ^/api/(.*) content/cq:graphql/whitelabel/endpoint [PT,L]

RewriteCond %{REQUEST_URI} !^/apps
RewriteCond %{REQUEST_URI} !^/bin
RewriteCond %{REQUEST_URI} !^/content
RewriteCond %{REQUEST_URI} !^/etc
RewriteCond %{REQUEST_URI} !^/libs
RewriteCond %{REQUEST_URI} !^/saml_login
RewriteCond %{REQUEST_URI} !^/system
RewriteCond %{REQUEST_URI} !^/tmp
RewriteCond %{REQUEST_URI} !^/var
RewriteCond %{REQUEST_URI} !^/api
RewriteCond %{REQUEST_URI} !^/library
RewriteRule ^/(.*)$ /content/${CONTENT_FOLDER_NAME}/gb/en/$1 [PT,L]

