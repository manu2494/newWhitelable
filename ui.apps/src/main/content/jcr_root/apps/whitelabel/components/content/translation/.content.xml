<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        jcr:primaryType="nt:unstructured"
        jcr:title="Merkle - Translation Tool"
        sling:resourceType="granite/ui/components/shell/page"
        consoleId="translation-tool">
        <head
            granite:class="admin-head"
            jcr:primaryType="nt:unstructured">
            <clientlibs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/includeclientlibs"
                categories="[granite.ui.coral.foundation,translation-admin-tool.base]"/>
        </head>
        <title
            jcr:primaryType="nt:unstructured"
            jcr:title="Merkle Translation Tool"
            sling:resourceType="granite/ui/components/shell/title"/>
        <content
            granite:class="admin-page"
            jcr:primaryType="nt:unstructured"
            sling:resourceType="granite/ui/components/coral/foundation/container"
            margin="{Boolean}false">
            <items jcr:primaryType="nt:unstructured">
                <column
                    granite:class="left-col"
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/container"
                    margin="{Boolean}false">
                    <items jcr:primaryType="nt:unstructured">
                        <title
                            granite:class="admin-title"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/text"
                            text="Translation Inputs"/>
                        <translation-inputs
                            granite:class="translation-inputs"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/container"
                            margin="{Boolean}true">
                            <items jcr:primaryType="nt:unstructured">
                                <well
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/well"
                                    margin="{Boolean}true">
                                    <items jcr:primaryType="nt:unstructured">
                                        <container
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form"
                                            enctype="multipart/form-data"
                                            foundationForm="{Boolean}true"
                                            loadingMask="{Boolean}true"
                                            margin="{Boolean}true"
                                            maximized="{Boolean}true"
                                            style="vertical">
                                            <items jcr:primaryType="nt:unstructured">
                                                <translation-excel-file-path
                                                    granite:id="translationExcelFilePath"
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                    emptyText="Translation Excel File Path"
                                                    fieldLabel="Choose path to translation excel file"
                                                    required="{Boolean}true"
                                                    rootPath="/content/dam"/>
                                                <select-platform
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                    fieldDescription="Select Platform"
                                                    fieldLabel="Select Platform"
                                                    name="./selectedPlatform"
                                                    required="{Boolean}true">
                                                    <datasource
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="/bin/listPlatforms"/>
                                                </select-platform>
                                                <select-translations-btn
                                                    granite:class="selectTranslationsBtn"
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/button"
                                                    text="Select"
                                                    type="submit"/>
                                            </items>
                                        </container>
                                    </items>
                                </well>
                            </items>
                        </translation-inputs>
                    </items>
                </column>
                <column2
                    granite:class="right-col"
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/container"
                    margin="{Boolean}false">
                    <items jcr:primaryType="nt:unstructured">
                        <title
                            granite:class="admin-title"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/text"
                            text="Details"/>
                        <details
                            granite:class="edit-details"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/container"
                            margin="{Boolean}false">
                            <items jcr:primaryType="nt:unstructured"/>
                        </details>
                    </items>
                </column2>
                <column3
                    granite:class="dialogs"
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                    margin="{Boolean}false">
                    <items jcr:primaryType="nt:unstructured">
                        <column
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/container"
                            margin="{Boolean}true">
                            <items jcr:primaryType="nt:unstructured">
                                <translation-inputs
                                    granite:class="add-translation-inputs"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/container"
                                    margin="{Boolean}true">
                                    <items jcr:primaryType="nt:unstructured">
                                        <well
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/well"
                                            margin="{Boolean}true">
                                            <items jcr:primaryType="nt:unstructured">
                                                <container
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/form"
                                                    enctype="multipart/form-data"
                                                    foundationForm="{Boolean}true"
                                                    loadingMask="{Boolean}true"
                                                    margin="{Boolean}true"
                                                    maximized="{Boolean}true"
                                                    style="vertical">
                                                    <items jcr:primaryType="nt:unstructured">
                                                        <run-all-languages
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                            checked="{Boolean}false"
                                                            fieldLabel="All"
                                                            name="./all"
                                                            text="All"/>
                                                        <run-translations-btn
                                                            granite:class="runTranslationsBtn"
                                                            jcr:primaryType="nt:unstructured"
                                                            sling:resourceType="granite/ui/components/coral/foundation/button"
                                                            text="Run"
                                                            type="submit"/>
                                                    </items>
                                                </container>
                                            </items>
                                        </well>
                                    </items>
                                </translation-inputs>
                            </items>
                        </column>
                    </items>
                </column3>
            </items>
        </content>
    </jcr:content>
</jcr:root>
